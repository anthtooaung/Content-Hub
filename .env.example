# .env.example — commit THIS file, never your real .env.
#
#   1. `.env` is gitignored. Never commit real keys.
#   2. Copy it:  cp .env.example .env   then fill real values locally.
#   3. If a real key ever lands in a commit, it is compromised — ROTATE it (regenerate).

# --- App ---
APP_ENV=development
PORT=3000

# --- Database ---
DATABASE_URL=postgresql://username:password@localhost:5432/content_hub

# --- Auth ---
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# --- AI / LLM (use one or both) ---
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
