generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum login_provider_type {
  email
  google
  facebook
  tiktok
}

enum oauth_provider_type {
  google
  facebook
  tiktok
  instagram
}

enum platform_type {
  facebook
  instagram
  linkedin
  twitter
  tiktok
}

enum tone_type {
  professional
  casual
  humorous
  inspirational
  educational
}

enum generation_status {
  pending
  processing
  completed
  failed
}

enum ai_response_status {
  draft
  ready_to_post
  posted
  failed
}

enum post_status {
  pending
  posted
  failed
}

// ─── TABLES ──────────────────────────────────────────────

/// Self-managed user table — handles both email/password and OAuth signups.
/// Password is hashed (bcrypt) at the application layer before storing.
/// OAuth-only users will have password_hash = NULL.
model users {
  id                     String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                  String               @unique @db.VarChar(255)
  name                   String?              @db.VarChar(255)
  avatar_url             String?
  password_hash          String?              /// bcrypt hash — NULL for OAuth-only users
  email_verified         Boolean              @default(false)
  primary_login_provider login_provider_type   @default(email)
  created_at             DateTime             @default(now()) @db.Timestamptz()
  updated_at             DateTime             @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  social_connections  social_connections[]
  businesses          businesses[]
  content_generations content_generations[]
  published_posts     published_posts[]
  saved_posts         saved_posts[]
  contents            Content[]
  scheduled_posts     ScheduledPost[]
}

model social_connections {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String              @db.Uuid
  provider          oauth_provider_type
  provider_user_id  String?             @db.VarChar(255)
  provider_username String?             @db.VarChar(255)
  access_token      String?
  refresh_token     String?
  token_expires_at  DateTime?           @db.Timestamptz()
  platform_page_id  String?             @db.VarChar(255)
  used_for_login    Boolean             @default(false)
  used_for_posting  Boolean             @default(false)
  is_active         Boolean             @default(true)
  connected_at      DateTime            @default(now()) @db.Timestamptz()
  updated_at        DateTime            @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  user            users             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  published_posts published_posts[]
  scheduled_posts ScheduledPost[]

  @@unique([user_id, provider, provider_user_id])
}

model businesses {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String    @db.Uuid
  business_name   String    @db.VarChar(255)
  industry        String?   @db.VarChar(100)
  target_audience String?
  deleted_at      DateTime? @db.Timestamptz()
  created_at      DateTime  @default(now()) @db.Timestamptz()
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  user                users                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  content_generations content_generations[]
}

model content_generations {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String            @db.Uuid
  business_id         String?           @db.Uuid
  platform            platform_type
  tone                tone_type
  language            String?           @db.VarChar(10)
  prompt              String
  image_url           String?
  auto_post_requested Boolean           @default(false)
  status              generation_status @default(pending)
  created_at          DateTime          @default(now()) @db.Timestamptz()

  // Relations
  user         users          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  business     businesses?    @relation(fields: [business_id], references: [id], onDelete: SetNull)
  ai_responses ai_responses[]
}

model ai_responses {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content_generation_id String             @db.Uuid
  generated_content     String
  hashtags              String[]
  call_to_action        String?
  ai_model              String?            @db.VarChar(100)
  tokens_used           Int?
  status                ai_response_status @default(draft)
  created_at            DateTime           @default(now()) @db.Timestamptz()

  // Relations
  content_generation content_generations @relation(fields: [content_generation_id], references: [id], onDelete: Cascade)
  published_posts    published_posts[]
  saved_posts        saved_posts[]
}

model published_posts {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id              String        @db.Uuid
  ai_response_id       String        @db.Uuid
  social_connection_id String        @db.Uuid
  platform             platform_type
  external_post_id     String?       @db.VarChar(255)
  caption_used         String?
  image_url            String?
  status               post_status   @default(pending)
  error_message        String?
  posted_at            DateTime?     @db.Timestamptz()
  created_at           DateTime      @default(now()) @db.Timestamptz()

  // Relations
  user              users              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ai_response       ai_responses       @relation(fields: [ai_response_id], references: [id], onDelete: Cascade)
  social_connection social_connections  @relation(fields: [social_connection_id], references: [id], onDelete: Cascade)
}

model saved_posts {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String   @db.Uuid
  ai_response_id String   @db.Uuid
  title          String?  @db.VarChar(255)
  is_favorite    Boolean  @default(false)
  notes          String?
  created_at     DateTime @default(now()) @db.Timestamptz()
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz()

  // Relations
  user        users        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ai_response ai_responses @relation(fields: [ai_response_id], references: [id], onDelete: Cascade)
}

model Content {
  id            String    @id @default(cuid())
  userId        String    @db.Uuid
  platform      String
  tone          String?
  topic         String?   @db.Text
  post          String    @db.Text
  hashtags      String[]
  caption       String?   @db.Text
  callToAction  String?   @db.Text
  createdAt     DateTime  @default(now())

  // Scoring fields (Phase 7)
  scoreReadability      Int?
  scoreHashtagRelevance Int?
  scoreCtaStrength      Int?
  scoreOverall          Int?
  scoreGrade            String?   @db.VarChar(2)
  scoreSuggestions      String?   @db.Text  // JSON array of suggestions

  // Analytics fields (Phase 6)
  viewCount      Int      @default(0)
  lastAccessedAt DateTime?

  // Relations
  user           users           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledPosts ScheduledPost[]
  postMetrics    PostMetric[]

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model ScheduledPost {
  id                  String   @id @default(cuid())
  userId              String   @db.Uuid
  contentId           String
  socialConnectionId  String   @db.Uuid
  platform            String   // "facebook" | "instagram"
  scheduledAt         DateTime
  status              String   @default("scheduled") // scheduled | publishing | published | failed | cancelled
  publishedAt         DateTime?
  externalPostId      String?  @db.VarChar(255)
  errorMessage        String?  @db.Text
  retryCount          Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  user            users             @relation(fields: [userId], references: [id], onDelete: Cascade)
  content         Content           @relation(fields: [contentId], references: [id], onDelete: Cascade)
  socialConnection social_connections @relation(fields: [socialConnectionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, scheduledAt])
}

model PostMetric {
  id              String   @id @default(cuid())
  contentId       String
  platform        String
  likes           Int      @default(0)
  comments        Int      @default(0)
  shares          Int      @default(0)
  impressions     Int      @default(0)
  engagementRate  Float    @default(0)
  fetchedAt       DateTime @default(now())

  // Relations
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}
